# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/devai_pro

# JWT
JWT_SECRET=replace_this_with_a_secure_secret

# Super admin seed
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=ChangeMePlease!123
# Optional: sync env password to DB user on every boot
SYNC_SUPER_ADMIN_PASSWORD=false

# Remote Ollama
# Local development:
# OLLAMA_API_URL=http://localhost:11434/api/generate
# Production (Render -> tunnel URL):
OLLAMA_API_URL=https://YOUR_TUNNEL_URL/api/generate
OLLAMA_MODEL=llama3.2
MAX_PROMPT_CHARS=12000
OLLAMA_TIMEOUT_MS=120000
OLLAMA_HEALTH_TIMEOUT_MS=10000

# AI quota
FREE_DAILY_LIMIT=50

# Frontend CORS
# Local: http://localhost:5173
# Render static site: https://your-frontend.onrender.com
FRONTEND_ORIGIN=http://localhost:5173
APP_BASE_URL=http://localhost:5173

# Password reset
RESET_PASSWORD_TOKEN_EXPIRES_MINUTES=30
# Set to true only for local testing or temporary support operation.
EXPOSE_RESET_TOKEN_RESPONSE=true

# Generated project files root directory
# Local default: {server}/projects
# Render recommended: /tmp/devai-projects (ephemeral) or mounted disk path
PROJECTS_ROOT_DIR=/tmp/devai-projects

# Stripe
STRIPE_SECRET=sk_test_...
STRIPE_SUCCESS_URL=https://yourapp.com/success
STRIPE_CANCEL_URL=https://yourapp.com/cancel
STRIPE_RETURN_URL=https://yourapp.com/account
STRIPE_WEBHOOK_SECRET=whsec_...

# Server
PORT=4000
